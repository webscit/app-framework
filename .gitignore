# macOS
.DS_Store

# Python
.venv/
__pycache__/
*.py[cod]
*.pyc
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node / frontend
node_modules/
packages/*/node_modules/
examples/*/node_modules/

# Compiled output — never commit these
dist/
packages/*/dist/
examples/frontend/dist/
pypackages/framework-core/dist/
*.tsbuildinfo

# Test & report artefacts
playwright-report/
test-results/

# Environment files — never commit real secrets
.env
.env.local
.env.*
examples/**/.env

# Tooling caches
.cache/
.e2e-venv/
uv.lock
packages/framework-core-ui/.vitest-attachments/
**/__screenshots__/
