{
  "name": "app-framework",
  "private": true,
  "workspaces": [
    "packages/framework-core-ui",
    "examples/frontend",
    "examples/reachy_mini/frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w @app-framework/examples-frontend",
    "dev:reachy-mini": "npm run dev -w @app-framework/reachy-mini-frontend",
    "build": "npm run build --workspaces --if-present",
    "format:check": "prettier --check .",
    "lint": "eslint packages examples/frontend examples/reachy_mini/frontend",
    "typecheck": "tsc -b packages/framework-core-ui/tsconfig.json examples/frontend/tsconfig.json examples/reachy_mini/frontend/tsconfig.json",
    "test:ui": "npm run test -w @app-framework/core-ui -- --run && npm run test -w @app-framework/examples-frontend -- --run && npm run test -w @app-framework/reachy-mini-frontend -- --run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.0",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.3.0",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-darwin-arm64": "^4.3.0"
  }
}
