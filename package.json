{
  "name": "app-framework",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w packages/ui-shell",
    "build": "npm run build --workspaces --if-present",
    "format:check": "prettier --check .",
    "lint": "eslint packages",
    "typecheck": "tsc -b packages/ui-shell/tsconfig.json",
    "test:ui": "npm run test -w packages/ui-shell -- --run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@eslint/js": "^9.39.4",
    "eslint": "^9",
    "prettier": "^3",
    "typescript": "^5",
    "typescript-eslint": "^8.58.1"
  }
}
