# Copy this file to .env and fill in your values before starting the backend.

# OpenRouter API key — required for the /ai/layout endpoint.
# Get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Recommended default (balanced speed + capability):
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# Cheaper/faster alternative:
# OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4.5-20251001

# Free smoke-test option (rate-limited, no credits needed):
# OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional tuning — defaults are fine for most use cases.
# OPENROUTER_MAX_TOKENS=2048
# OPENROUTER_TEMPERATURE=0.2
