# OpenRouter API key — required for the /ai/layout endpoint.
# Get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Model to use for layout generation. Any OpenRouter-supported model works.
# Cheaper/faster alternative: anthropic/claude-3-haiku
# Free smoke-test option: mistralai/mistral-7b-instruct:free
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# Optional tuning — defaults are fine for most use cases.
# OPENROUTER_MAX_TOKENS=2048
# OPENROUTER_TEMPERATURE=0.2
