# Copy this file to .env and fill in your values before starting the backend.

# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Override the default AI model used for layout generation.
# Any model available on OpenRouter works; the default is a good balance
# of quality and cost for structured JSON output.
# Default: anthropic/claude-sonnet-4.6
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6
